{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "工资条发送器",
  "version": "0.1.0",
  "identifier": "cn.beeworks.payslip",
  "build": {
    "beforeDevCommand": "vite --host 0.0.0.0 --port 3000",
    "beforeBuildCommand": "npm run build:web",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "工资条发送器",
        "width": 980,
        "height": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg",
      "msi"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "bundleName": "工资条发送器",
      "bundleVersion": "1",
      "minimumSystemVersion": "11.0",
      "hardenedRuntime": true,
      "entitlements": "Entitlements.plist"
    }
  }
}
